# Supabase cloud sync
VITE_SUPABASE_URL=https://wljgjyonvcorneoyxotd.supabase.co

# Publishable key (sb_publishable_...) — NOT the secret key
VITE_SUPABASE_ANON_KEY=

# Login and password — same as before (stored in Vercel env)
VITE_ACCOUNT_1_USERNAME=
VITE_ACCOUNT_1_PASSWORD=
VITE_ACCOUNT_1_NAME=

VITE_ACCOUNT_2_USERNAME=
VITE_ACCOUNT_2_PASSWORD=
VITE_ACCOUNT_2_NAME=

# OpenAI Coach (server-side only — set in Vercel, then Redeploy)
OPENAI_API_KEY=
# Optional: gpt-4o-mini (default), gpt-4o, etc.
OPENAI_MODEL=

# Optional: lets Coach work after app restore without re-login
# Same random string in Vercel as ASSISTANT_SECRET and VITE_ASSISTANT_SECRET
ASSISTANT_SECRET=
VITE_ASSISTANT_SECRET=

# Internal email for cloud auth: {username}@{domain}
VITE_AUTH_EMAIL_DOMAIN=life-quest.app
